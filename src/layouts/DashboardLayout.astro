---
export interface Props {
  title?: string;
}
const { title = "AgriSense — Smart Farm Monitor" } = Astro.props;
---
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content="Dashboard monitoring sensor pertanian real-time untuk petani modern">
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/mqtt/5.3.5/mqtt.min.js"></script>
  <link rel="stylesheet" href="/style.css">
  <!-- Order matters! Config first, then services, then main app -->
  <script is:inline src="/js/config/config.js" defer></script>
  <script is:inline src="/js/config/config.local.js" defer></script>
  <script is:inline src="/js/config/sensors.config.js" defer></script>
  <script is:inline src="/js/services/data-store.js" defer></script>
  <script is:inline src="/js/renderer/gauge-renderer.js" defer></script>
  <script is:inline src="/js/renderer/chart-manager.js" defer></script>
  <script is:inline src="/js/services/threshold-service.js" defer></script>
  <script is:inline src="/js/services/mqtt-manager.js" defer></script>
  <script is:inline src="/js/services/sensor-service.js" defer></script>
  <script is:inline src="/ml-engine.js" defer></script>
  <script is:inline src="/recommendations.js" defer></script>
  <script is:inline src="/js/core/script.js" defer></script>
</head>
<body>
  <slot />
</body>
</html>
